DJANGO_SECRET_KEY=replace-with-your-own-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOW_ALL_ORIGINS=True

# ฐานข้อมูลหลัก (อ่านข้อมูลคิวรถ / Yard / สินค้า) — โดยทั่วไปคือ OBM_DWMS
DB_ENGINE=mssql
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=your_database_host_or_ip
DB_PORT=1433
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=True

# ฐานข้อมูล log (เขียนประวัติแจ้งเตือน + ผลพยากรณ์) — โดยทั่วไปคือ WMS
# หากอยู่บน SQL Server เครื่องเดียวกับชุดหลัก ให้ใส่ค่า HOST/USER/PASSWORD เหมือนกัน เปลี่ยนแค่ NAME
LOG_DB_ENGINE=mssql
LOG_DB_NAME=WMS
LOG_DB_USER=your_database_user
LOG_DB_PASSWORD=your_database_password
LOG_DB_HOST=your_database_host_or_ip
LOG_DB_PORT=1433
LOG_DB_TRUST_SERVER_CERTIFICATE=True
